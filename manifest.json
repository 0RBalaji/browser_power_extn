{
  "manifest_version": 3,
  "name": "Dark Browser - Auto Dark Mode",
  "version": "2.2.1",
  "description": "Auto dark mode for the web, optional network ad blocking, and per-site controls",
  "permissions": [
    "activeTab",
    "declarativeNetRequest",
    "scripting",
    "storage"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "adblock_rules",
        "enabled": false,
        "path": "rules/ad_rules.json"
      }
    ]
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/extension/content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "src/extension/background.js"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Dark Browser"
  }
}
